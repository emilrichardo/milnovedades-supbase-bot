# =============================================================================
# ENVIRONMENT VARIABLES - Copy to .env and fill in your values
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_PASSWORD=your-super-secret-password-change-me

# =============================================================================
# AUTH / JWT
# Generate keys: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# =============================================================================
JWT_SECRET=your-super-secret-jwt-token-at-least-32-chars-long
ANON_KEY=your-anon-key-generated-from-jwt-secret
SERVICE_ROLE_KEY=your-service-role-key-generated-from-jwt-secret

# =============================================================================
# URLS
# =============================================================================
# URL where Supabase Kong gateway is reachable publicly (for auth redirects, etc.)
SUPABASE_PUBLIC_URL=http://localhost:8080

# Payload CMS server URL (for CORS and CSRF)
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
SERVER_URL=http://localhost:3000

# Auth redirect URLs
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=http://localhost:3000

# =============================================================================
# ALEPH ERP API
# =============================================================================
ALEPH_API_URL=http://aleph.dyndns.info/integracion/api
ALEPH_API_KEY=ADCT-8100-0004
ALEPH_CLIENT_ID=LASMILNOVEDADES

# =============================================================================
# WOOCOMMERCE API
# =============================================================================
WC_API_URL=https://lasmilnovedades.com/wp-json
WC_CONSUMER_KEY=ck_a0c1ff25388202902f6cc9899b5f19833453a04e
WC_CONSUMER_SECRET=cs_869f377138991a1c1776b6e2d8f3011f0b949e6f

# =============================================================================
# PAYLOAD CMS
# =============================================================================
# Secret key for Payload CMS (min 32 chars)
PAYLOAD_SECRET=your-payload-secret-key-at-least-32-chars-long

# PostgreSQL connection string for Payload CMS
# Uses supabase_admin role which has full access to the payload schema
DATABASE_URI=postgres://supabase_admin:your-super-secret-password-change-me@db:5432/postgres

# =============================================================================
# AI API KEYS (for edge functions / AI agents)
# =============================================================================
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# =============================================================================
# MISC
# =============================================================================
REALTIME_ENC_KEY=secure-key-for-realtime-channels
APP_ENV=local
