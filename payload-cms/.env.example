# Payload CMS environment variables
# When running via docker-compose, these are injected by docker-compose.yaml
# For local development outside Docker, copy to .env and fill in values

# PostgreSQL connection (must point to the postgres database, payload schema is auto-managed)
DATABASE_URL=postgres://supabase_admin:your-password@localhost:5432/postgres

# Payload secret key (min 32 chars)
PAYLOAD_SECRET=your-payload-secret-key-at-least-32-chars-long

# Public server URL (for CORS/CSRF)
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
SERVER_URL=http://localhost:3000

# Supabase integration (optional, for client-side use)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8080
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
